<manifest xmlns:android="http://schemas.android.com/apk/res/android" android:versionCode="1" android:versionName="1.0" package="com.dstrube.androidtablayout.app">
    <uses-sdk android:minSdkVersion="8" android:targetSdkVersion="19"/>

    <application android:allowBackup="true" android:icon="@drawable/ic_launcher" android:label="@string/app_name" android:theme="@style/AppTheme">
        <activity android:label="@string/app_name" android:name="com.dstrube.androidtablayout.app.AndroidTabLayoutActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>

                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity android:label="@string/title_activity_photos" android:name="com.dstrube.androidtablayout.app.PhotosActivity">
        </activity>
        <activity android:label="@string/title_activity_songs" android:name="com.dstrube.androidtablayout.app.SongsActivity">
        </activity>
        <activity android:label="@string/title_activity_videos" android:name="com.dstrube.androidtablayout.app.VideosActivity">
        </activity>
    </application>

</manifest>
